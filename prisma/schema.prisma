// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
  runtime    = "bun"
}

datasource db {
  provider     = "sqlite"
  relationMode = "foreignKeys"
}

model ProjectCommits {
  id          Int          @id @default(autoincrement())
  projectPath String       @unique
  commits     CommitData[]
}

model CommitData {
  id        Int              @id @default(autoincrement())
  changes   CommitChange[]
  statsId   Int              @unique // Index of changes
  stats     CommitDataStats? @relation(fields: [statsId], references: [id])
  elapsedMs BigInt
  timestamp DateTime

  projectCommit   ProjectCommits? @relation(fields: [projectCommitId], references: [id])
  projectCommitId Int?
}

model CommitChange {
  id            Int    @id @default(autoincrement())
  changeMessage String
  changesNumber Int

  commitData CommitData @relation(fields: [commitId], references: [id])
  commitId   Int
}

model CommitDataStats {
  id           Int    @id @default(autoincrement())
  modelVersion String

  usageMetadata   CommitDataStatsUsageMetadata? @relation(references: [id], fields: [usageMetadataId])
  usageMetadataId Int

  commitData CommitData?
}

model CommitDataStatsUsageMetadata {
  id                   Int    @id @default(autoincrement())
  promptTokenCount     BigInt
  candidatesTokenCount BigInt
  totalTokenCount      BigInt

  promptTokensDetails CommitDataStatsUsageMetadataPromtTokensDetails[]
  commitDataStats     CommitDataStats[]
}

model CommitDataStatsUsageMetadataPromtTokensDetails {
  id              Int                          @id @default(autoincrement()) // 1, 2, 3, ...
  modality        String
  tokenCount      BigInt
  usageMetadata   CommitDataStatsUsageMetadata @relation(fields: [usageMetadataId], references: [id])
  usageMetadataId Int
}
