// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
  runtime    = "bun"
}

datasource db {
  provider     = "sqlite"
  relationMode = "foreignKeys"
}

model Project {
  id                 Int      @id @default(autoincrement())
  createdAt          DateTime @default(now())
  lastModified       DateTime @default(now())
  projectPath        String   @unique
  commitAIIdentifier String   @unique

  commits CommitInfo[]
}

// single commit
model CommitInfo {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  lastModified DateTime @default(now())

  commitMessages CommitMessage[]

  statistics         CommitStatistics @relation(fields: [commitStatisticsId], references: [id])
  commitStatisticsId Int

  project   Project? @relation(fields: [projectId], references: [id])
  projectId Int?
}

// only commit messages
model CommitMessage {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  lastModified DateTime @default(now())

  message String

  commitInfo   CommitInfo? @relation(fields: [commitInfoId], references: [id])
  commitInfoId Int?
}

model CommitStatistics {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  lastModified DateTime @default(now())

  modelVersion         String
  promptTokenCount     BigInt
  candidatesTokenCount BigInt
  totalTokenCount      BigInt
  tokenCount           BigInt
  modality             String
  commitInfos          CommitInfo[]
}
